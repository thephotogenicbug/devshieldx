{
  "name": "devshieldx",
  "displayName": "DevShieldX Code Security Scanner",
  "description": "Detect vulnerabilities like XSS, SQL Injection, eval misuse and more in JavaScript & TypeScript",
  "version": "0.2.0",
  "publisher": "Naveendev",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "contributes": {
    "commands": [
      {
        "command": "devshieldx.fixAll",
        "title": "DevShieldX: Fix All Security Issues"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thephotogenicbug/devshieldx"
  },
  "homepage": "https://github.com/thephotogenicbug/devshieldx",
  "bugs": {
    "url": "https://github.com/thephotogenicbug/devshieldx/issues"
  },
  "license": "MIT",
  "keywords": [
    "security",
    "scanner",
    "javascript",
    "typescript",
    "vscode",
    "xss",
    "sql-injection",
    "sast",
    "static-analysis"
  ]
}
